# macOS Developer ID signing + notarization for local release builds.
#
# Copy this file to `.env.signing` (which is gitignored) and fill in the values.
# `build-release.sh` sources `.env.signing` automatically on macOS and passes
# these through to `tauri build`, which then signs, notarizes and staples the
# .app / .dmg so downloaded copies open without a Gatekeeper warning.
#
# The signing certificate itself lives in your login keychain (verify with
# `security find-identity -v -p codesigning`); only these settings live here.

# --- Signing --------------------------------------------------------------
# The exact name of your "Developer ID Application" identity.
APPLE_SIGNING_IDENTITY="Developer ID Application: Nena Innovation AB (3286TR25A4)"

# --- Notarization (App Store Connect API key) -----------------------------
# Create the key at https://appstoreconnect.apple.com/access/integrations/api
# (role: Developer). Download the AuthKey_XXXXXXXXXX.p8 ONCE and keep it safe.
#
# APPLE_API_ISSUER   = the Issuer ID (UUID shown above the keys table)
# APPLE_API_KEY      = the Key ID (the 10-char id, e.g. ABCD123456)
# APPLE_API_KEY_PATH = absolute path to the downloaded .p8 file
APPLE_API_ISSUER=""
APPLE_API_KEY=""
APPLE_API_KEY_PATH="$HOME/.appstoreconnect/private_keys/AuthKey_XXXXXXXXXX.p8"
