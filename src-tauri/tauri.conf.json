{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MarkDown Commander",
  "version": "0.1.0",
  "identifier": "com.mdcmd",
  "build": {
    "beforeDevCommand": "node src-tauri/scripts/patch-ios-plist.mjs && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node src-tauri/scripts/patch-ios-plist.mjs && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MarkDown Commander",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdown", "qmd"],
        "name": "Markdown Document",
        "role": "Editor",
        "mimeType": "text/markdown",
        "contentTypes": ["net.daringfireball.markdown", "public.plain-text"]
      }
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUyRDJFNTBGNkM1NzE2QjQKUldTMEZsZHNEK1hTVWttRWY0MTRlRWVWai9DSy93dFQ2dFU5ZnBPTjA3bXBLeW1NR0Ewd3JhL0wK",
      "endpoints": [
        "https://github.com/apstrand/mdcmd/releases/latest/download/latest.json"
      ]
    }
  }
}
